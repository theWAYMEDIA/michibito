{{- $pages := where .Site.RegularPages "Type" "not in" (slice "page") -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "summary": {{ $p.Summary | jsonify }},
    "content": {{ $p.Plain | jsonify }}
  }
  {{- end -}}
]
